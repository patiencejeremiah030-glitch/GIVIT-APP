# Relative URL → Vite proxies /api to Django on port 8001 (avoids CORS in local dev)
# Start backend: python manage.py runserver 8001
VITE_API_URL=/api/v1

# Google Analytics 4 — optional (leave empty to disable)
# Create a property at https://analytics.google.com/ and copy the Measurement ID (G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=
